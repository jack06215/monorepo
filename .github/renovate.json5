{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",

  extends: [
    "config:recommended",
    ":dependencyDashboard",
    ":semanticCommits",
  ],

  // ---------------------------------------------------------------------------
  // Scope
  // ---------------------------------------------------------------------------

  // Poetry only. This allowlist is load-bearing: without it Renovate's
  // `pip_requirements` manager parses requirements.txt -- 4348 lines of pinned,
  // hashed, fully-resolved transitive deps -- and raises a PR per entry.
  enabledManagers: ["poetry"],

  // The poetry manager globs every pyproject.toml in the tree. The two plugin
  // manifests are PEP 621 (`[project]`, no `[tool.poetry]` table) so they are
  // skipped today; excluding them explicitly keeps that true if either ever
  // gains a `[tool.poetry]` section.
  ignorePaths: ["packages/llm_cli/plugins/**"],

  // requirements.txt is a generated artifact (`poetry export`), regenerated by
  // postUpgradeTasks below. Renovate must never treat it as a source of truth.
  "pip_requirements": {
    enabled: false,
  },

  // `[tool.poetry.dependencies] python` is a dependency like any other to the
  // poetry manager, and 3.13 -> 3.14 reads as a minor update, so it silently
  // landed in the grouped non-major PR and broke the lock step:
  //   "The currently activated Python version 3.13.13 is not supported by the
  //    project (3.14.6)"
  //
  // The interpreter is pinned in three places Renovate cannot see --
  // .tool-versions, MODULE.bazel:24 (python.toolchain) and MODULE.bazel:31
  // (pip.parse) -- so bumping it here alone desyncs the Bazel toolchain.
  // Python upgrades stay a deliberate, coordinated, human change.
  ignoreDeps: ["python"],

  // ---------------------------------------------------------------------------
  // Toolchain
  // ---------------------------------------------------------------------------

  // pyproject.toml pins `python = "3.13.13"` -- an exact patch. Renovate runs
  // poetry against an interpreter it provisions itself (binarySource=install),
  // so it has to be told which one; otherwise poetry aborts with "the currently
  // activated Python version is not supported by the project".
  constraints: {
    python: "3.13.13",
  },

  // ---------------------------------------------------------------------------
  // Cadence and PR policy
  // ---------------------------------------------------------------------------

  timezone: "Asia/Tokyo",

  // Weekly window: Monday 00:00-06:00 Asia/Tokyo.
  schedule: ["* 0-6 * * 1"],

  // Everything lands as a PR for a human to merge. Renovate never commits to
  // master and never merges its own work.
  automerge: false,
  platformAutomerge: false,

  dependencyDashboard: true,
  rebaseWhen: "conflicted",

  // 2 = room for the non-major group PR plus one major PR open at once,
  // without letting majors queue up indefinitely behind each other.
  prConcurrentLimit: 2,
  prHourlyLimit: 0,

  // Caret ranges, bumped forward on every update: `bump` moves the range's
  // floor to match the newest allowed version (e.g. ^6.9.0 -> ^6.10.1), so the
  // manifest diff still shows the version change per PR, without collapsing
  // the range to an exact pin. package-mode = false (this is an app, not a
  // published library) doesn't require ranges, but pyproject.toml is meant to
  // read as human-authored intent; requirements.txt (regenerated below) stays
  // the fully pinned and hashed artifact that Bazel actually consumes.
  //
  // Previously this was `rangeStrategy: "pin"`, because pinning was the only
  // way to make `minimumReleaseAge` reliable: with a caret range, poetry
  // resolves to the newest matching version regardless of what Renovate
  // proposed, which could still be inside the age window --
  //   "Artifact update for colorlog resolved to version 6.11.0, which is a
  //    pending version that has not yet passed the Minimum Release Age"
  // Renovate cannot hand poetry an exact target to enforce that against
  // (renovatebot/renovate#41624). We dropped minimumReleaseAge below instead
  // of keeping everything pinned.
  rangeStrategy: "bump",

  // No minimumReleaseAge: see the rangeStrategy comment above -- it isn't
  // enforceable against caret ranges under poetry, so keeping it here would
  // just be a false sense of protection. Revisit if upstream ever closes
  // renovatebot/renovate#41624.

  // ---------------------------------------------------------------------------
  // Keep the Bazel-consumed export in sync
  // ---------------------------------------------------------------------------

  // Renovate updates pyproject.toml + poetry.lock but knows nothing about
  // requirements.txt, which MODULE.bazel:31 feeds to pip.parse. Without this,
  // every PR would land with a stale export and fail
  // rules/python/poetry/check_requirements_txt.sh.
  //
  // `executionMode: "branch"` runs this once per branch after all updates in it
  // have been applied -- correct for the grouped PR below, where a per-update
  // run would re-export once per bumped dependency.
  //
  // Mirrors update_requirements_txt.sh exactly (no --without-hashes), so the
  // diff matches what the check script expects.
  postUpgradeTasks: {
    commands: [
      "poetry self add poetry-plugin-export",
      "poetry export -f requirements.txt -o requirements.txt",
    ],
    fileFilters: ["requirements.txt"],
    executionMode: "branch",
  },

  // ---------------------------------------------------------------------------
  // Grouping
  // ---------------------------------------------------------------------------

  packageRules: [
    // pytest, pandas-stubs and pytz carry their upper bounds directly in
    // pyproject.toml again (<8.2.0 / <2.2.4 / ~2024.2), now that ranges are
    // back -- no packageRule override needed to restate them.

    // ~85 direct deps: batch the boring ones into a single weekly PR.
    {
      matchManagers: ["poetry"],
      matchUpdateTypes: ["minor", "patch"],
      groupName: "python deps (non-major)",
      // Without this the branch is literally `renovate/python-deps-(non-major)`
      // -- parens are legal in a ref but need shell quoting on every checkout.
      // groupSlug sets the branch name independently of the PR title.
      groupSlug: "python-non-major",
      semanticCommitScope: "deps",
    },

    // Majors stay individual -- they need to be readable and revertable alone.
    {
      matchManagers: ["poetry"],
      matchUpdateTypes: ["major"],
      semanticCommitScope: "deps",
      labels: ["dependencies", "major"],
    },
  ],

  // Refresh the transitive tree periodically even when no direct dep moves.
  lockFileMaintenance: {
    enabled: true,
    schedule: ["* 0-6 * * 1"],
  },
}
