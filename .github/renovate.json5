{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",

  extends: [
    "config:recommended",
    ":dependencyDashboard",
    ":semanticCommits",
  ],

  // ---------------------------------------------------------------------------
  // Scope
  // ---------------------------------------------------------------------------

  // Poetry only. This allowlist is load-bearing: without it Renovate's
  // `pip_requirements` manager parses requirements.txt -- 4348 lines of pinned,
  // hashed, fully-resolved transitive deps -- and raises a PR per entry.
  enabledManagers: ["poetry"],

  // The poetry manager globs every pyproject.toml in the tree. The two plugin
  // manifests are PEP 621 (`[project]`, no `[tool.poetry]` table) so they are
  // skipped today; excluding them explicitly keeps that true if either ever
  // gains a `[tool.poetry]` section.
  ignorePaths: ["packages/llm_cli/plugins/**"],

  // requirements.txt is a generated artifact (`poetry export`), regenerated by
  // postUpgradeTasks below. Renovate must never treat it as a source of truth.
  "pip_requirements": {
    enabled: false,
  },

  // `[tool.poetry.dependencies] python` is a dependency like any other to the
  // poetry manager, and 3.13 -> 3.14 reads as a minor update, so it silently
  // landed in the grouped non-major PR and broke the lock step:
  //   "The currently activated Python version 3.13.13 is not supported by the
  //    project (3.14.6)"
  //
  // The interpreter is pinned in three places Renovate cannot see --
  // .tool-versions, MODULE.bazel:24 (python.toolchain) and MODULE.bazel:31
  // (pip.parse) -- so bumping it here alone desyncs the Bazel toolchain.
  // Python upgrades stay a deliberate, coordinated, human change.
  ignoreDeps: ["python"],

  // ---------------------------------------------------------------------------
  // Toolchain
  // ---------------------------------------------------------------------------

  // pyproject.toml pins `python = "3.13.13"` -- an exact patch. Renovate runs
  // poetry against an interpreter it provisions itself (binarySource=install),
  // so it has to be told which one; otherwise poetry aborts with "the currently
  // activated Python version is not supported by the project".
  constraints: {
    python: "3.13.13",
  },

  // ---------------------------------------------------------------------------
  // Cadence and PR policy
  // ---------------------------------------------------------------------------

  timezone: "Asia/Tokyo",

  // TEMPORARY (validation) -- revert to: schedule: ["* 0-6 * * 1"]
  // Widened so a manual dispatch can create a real PR now and finally exercise
  // the postUpgradeTasks export below, which no run has done yet. The 2026-07-18
  // run extracted 84 deps cleanly but fell on a Sunday, outside the Monday
  // window, so no branch was ever built.
  schedule: ["at any time"],

  // Everything lands as a PR for a human to merge. Renovate never commits to
  // master and never merges its own work.
  automerge: false,
  platformAutomerge: false,

  dependencyDashboard: true,
  rebaseWhen: "conflicted",

  // TEMPORARY (validation) -- remove once the pin PR has merged.
  // Closing a Renovate PR unmerged means "don't offer this again", and Renovate
  // honours that permanently. PRs #9/#10 (renovate/python-non-major) and #11
  // (renovate/python-pin) were closed during testing, so every run now creates
  // the branch, finds the closed PR, and aborts with "Repository has changed
  // during renovation". "always" ignores that memory so the branches get PRs.
  //
  // Do NOT leave this on: it makes every PR immortal -- closing one no longer
  // dismisses it, it returns on the next run.
  recreateWhen: "always",
  // Capped at 1 so the validation dispatch yields a single PR to inspect
  // instead of the grouped PR plus a separate PR per available major.
  prConcurrentLimit: 1,
  prHourlyLimit: 0,

  // Exact pins instead of caret ranges. This is what makes minimumReleaseAge
  // actually work: with `^6.10.1` in pyproject, poetry resolves the range to
  // the newest match and drags in a version still inside the age window, which
  // Renovate then rejects --
  //   "Artifact update for colorlog resolved to version 6.11.0, which is a
  //    pending version that has not yet passed the Minimum Release Age"
  // Renovate cannot hand poetry an exact target (renovatebot/renovate#41624),
  // so the range has to go. Correct here anyway: package-mode = false means
  // this is an app, not a published library, and requirements.txt is already
  // fully pinned and hashed as the real Bazel input.
  rangeStrategy: "pin",

  // Ignore any release younger than this. The common compromised-package
  // pattern -- publish a malicious version, get caught, version yanked -- plays
  // out within days, so holding new releases lets that happen to somebody else
  // first. Costs nothing given updates only land weekly anyway.
  //
  // Override for a single run via the workflow's `minimumReleaseAge` input,
  // e.g. "0 days" to pull in an urgent security fix immediately.
  minimumReleaseAge: "10 days",

  // ---------------------------------------------------------------------------
  // Keep the Bazel-consumed export in sync
  // ---------------------------------------------------------------------------

  // Renovate updates pyproject.toml + poetry.lock but knows nothing about
  // requirements.txt, which MODULE.bazel:31 feeds to pip.parse. Without this,
  // every PR would land with a stale export and fail
  // rules/python/poetry/check_requirements_txt.sh.
  //
  // `executionMode: "branch"` runs this once per branch after all updates in it
  // have been applied -- correct for the grouped PR below, where a per-update
  // run would re-export once per bumped dependency.
  //
  // Mirrors update_requirements_txt.sh exactly (no --without-hashes), so the
  // diff matches what the check script expects.
  postUpgradeTasks: {
    commands: [
      "poetry self add poetry-plugin-export",
      "poetry export -f requirements.txt -o requirements.txt",
    ],
    fileFilters: ["requirements.txt"],
    executionMode: "branch",
  },

  // ---------------------------------------------------------------------------
  // Grouping
  // ---------------------------------------------------------------------------

  packageRules: [
    // The one-time conversion of all 84 caret ranges to exact pins. Grouped so
    // it arrives as a single reviewable PR rather than 84 separate ones.
    {
      matchManagers: ["poetry"],
      matchUpdateTypes: ["pin"],
      groupName: "pin python deps",
      groupSlug: "python-pin",
      semanticCommitScope: "deps",
    },

    // Pinning deletes the upper bounds these three currently carry in
    // pyproject.toml, so restate them here or Renovate will start proposing
    // versions the project deliberately excludes. Drop any that turn out to be
    // stale rather than intentional.
    {
      matchManagers: ["poetry"],
      matchDepNames: ["pytest"],
      allowedVersions: "<8.2.0", // was: pytest = "<8.2.0"
    },
    {
      matchManagers: ["poetry"],
      matchDepNames: ["pandas-stubs"],
      allowedVersions: "<2.2.4", // was: pandas-stubs = ">=2.2.2.0,<2.2.4"
    },
    {
      matchManagers: ["poetry"],
      matchDepNames: ["pytz"],
      allowedVersions: "<2025.0", // was: pytz = "~2024.2"
    },

    // ~85 direct deps: batch the boring ones into a single weekly PR.
    {
      matchManagers: ["poetry"],
      matchUpdateTypes: ["minor", "patch"],
      groupName: "python deps (non-major)",
      // Without this the branch is literally `renovate/python-deps-(non-major)`
      // -- parens are legal in a ref but need shell quoting on every checkout.
      // groupSlug sets the branch name independently of the PR title.
      groupSlug: "python-non-major",
      semanticCommitScope: "deps",
    },

    // Majors stay individual -- they need to be readable and revertable alone.
    {
      matchManagers: ["poetry"],
      matchUpdateTypes: ["major"],
      semanticCommitScope: "deps",
      labels: ["dependencies", "major"],
    },
  ],

  // Refresh the transitive tree periodically even when no direct dep moves.
  lockFileMaintenance: {
    enabled: true,
    schedule: ["* 0-6 * * 1"],
  },
}
