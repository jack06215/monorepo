load("@monorepo_pip//:requirements.bzl", "requirement")
load("//rules/python/lint:defs.bzl", "py_binary", "py_library")

py_library(
    name = "hello_world_lib",
    srcs = ["main.py"],
    deps = [
        requirement("pydantic"),
        requirement("pandas"),
    ],
)

py_binary(
    name = "hello_world",
    srcs = ["main.py"],
    main = "main.py",
    deps = [
        ":hello_world_lib",
    ],
)
